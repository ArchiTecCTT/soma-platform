{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "base-nova",
  "rsc": false,
  "tsx": true,
  "tailwind": {
    "config": "tailwind.config.ts",
    "css": "src/styles.css",
    "baseColor": "slate",
    "cssVariables": true
  },
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "registries": {
    "@shadcn": "https://originui.com/r/{name}.json",
    "@reui": "https://reui.io/r/{style}/{name}.json",
    "@shadcn-space": "https://shadcnspace.com/r/{name}.json",
    "@prismui": "https://templete-prismui.vercel.app/r/{name}.json"
  }
}