{
  "name": "soma-platform",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "test": "pnpm -r test",
    "dev": "concurrently -k -n api,web,agent -c blue,green,magenta \"pnpm dev:api\" \"pnpm dev:web\" \"pnpm dev:agent\"",
    "dev:web": "pnpm --filter @soma/web dev",
    "dev:api": "pnpm --filter @soma/api dev",
    "dev:agent": "pnpm --filter @soma/agent dev"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
